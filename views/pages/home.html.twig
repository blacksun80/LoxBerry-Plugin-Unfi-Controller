{% extends 'pages/templates/adminBasePage.html.twig' %}


{% block body %}
	<div class="wide">UniFi Controller status</div>
	<p></p>
	<!-- info -->
	<div class="lb_flex-container">
		<div class="lb_flex-item-label">
			<label class="control-label">{{ trans('home.service_status') }}</label>
		</div>
		<div class="lb_flex-item-spacer"></div>
		<div class="lb_flex-item">
			<span id="fld_status">{{unifi_data.status}}</span>
		</div>
		<div class="lb_flex-item-spacer"></div>
		<div class="lb_flex-item-help hint">
			{{ trans('home.service_status_help') }}
		</div>
		<div class="lb_flex-item-spacer"></div>
	</div>

	<div id="failed_diag_hint" class="lb_flex-container" style="{% if unifi_data.status != 'failed' %}display:none;{% endif %}">
		<div class="lb_flex-item-help hint" style="width:100%;">
			<b>{{ trans('home.failed_hint') }}</b> <a href="{{ adminRouteUrl('diagnostics') }}">{{ trans('home.open_diagnostics') }}</a>
		</div>
	</div>

	<div class="lb_flex-container">
		<div class="lb_flex-item-label">
			<label class="control-label">{{ trans('home.container_version') }}</label>
		</div>
		<div class="lb_flex-item-spacer"></div>
		<div class="lb_flex-item">
			<span id="fld_container_version">{{unifi_data.containerVersion}}</span>

		</div>
		<div class="lb_flex-item-spacer"></div>
		<div class="lb_flex-item-help hint">
			{{ trans('home.container_version_help') }}
			<p>
				{{ trans('home.container_version_help_bold') }}
			</p>
		</div>
		<div class="lb_flex-item-spacer"></div>
	</div>

	<div class="lb_flex-container">
		<div class="lb_flex-item-label">
			<label class="control-label">{{ trans('home.controller_version') }}</label>
		</div>
		<div class="lb_flex-item-spacer"></div>
		<div class="lb_flex-item">
			<span id="fld_controller_version">{{unifi_data.version}}</span>
		</div>
		<div class="lb_flex-item-spacer"></div>
		<div class="lb_flex-item-help hint">
			{{ trans('home.controller_version_help') }}

		</div>
		<div class="lb_flex-item-spacer"></div>
	</div>

	<div class="wide">{{ trans('home.settings') }}</div>
	<p>
		<i>{{ trans('home.settings_desc') }}</i>

	</p>
	<form id="config" method="post" action="{{ adminRouteUrl('upgrade') }}">

		<div class="lb_flex-container">
			<div class="lb_flex-item-label">
				<label class="control-label">{{ trans('home.container_version') }}</label>
			</div>
			<div class="lb_flex-item-spacer"></div>
			<div class="lb_flex-item">
				<div class="ui-select ui-mini">
					<select id="version" name="version" data-mini="true">
						{% for version in versions %}
							<option value="{{version}}" {% if version == unifi_data.containerVersion %} selected {% endif %}>{{version}}</option>
						{% endfor %}
					</select>

				</div>
			</div>
			<div class="lb_flex-item-spacer"></div>
			<div class="lb_flex-item">
				<button type="submit" name="btnsubmit" id="btnsubmit" data-role="button" data-inline="true" data-mini="true" data-icon="check" class=" ui-btn ui-icon-check ui-btn-icon-left ui-btn-inline ui-shadow ui-corner-all ui-mini">{{ trans('home.settings_save') }}</button>
			</div>
			<div class="lb_flex-item-help hint">
				{{ trans('home.settings_save_hint') }}
				{% if versions_unavailable_for_architecture %}
					<p><b>{{ trans('home.architecture_notice')|replace({'%architecture%': host_architecture}) }}</b></p>
				{% endif %}
			</div>
		</div>
	</form>

	<div class="wide">{{ trans('home.reset_title') }}</div>
	<p>
		<i>{{ trans('home.reset_desc') }}</i>
	</p>
	<form id="reset" method="post" action="{{ adminRouteUrl('reset') }}" onsubmit="return confirm('{{ trans('home.reset_confirm') }}');">
		<div class="lb_flex-container">
			<div class="lb_flex-item">
				<button type="submit" name="btnreset" id="btnreset" data-role="button" data-inline="true" data-mini="true" data-icon="delete" class="ui-btn ui-icon-delete ui-btn-icon-left ui-btn-inline ui-shadow ui-corner-all ui-mini">{{ trans('home.reset_button') }}</button>
			</div>
			<div class="lb_flex-item-help hint">
				{{ trans('home.reset_hint') }}
			</div>
		</div>
	</form>

	<div class="wide">{{ trans('home.container_logs') }}</div>
	<p>
		<i>{{ trans('home.container_logs_desc') }}</i>
	</p>
	<div style="margin-bottom:8px;">
		<label style="display:inline-block; vertical-align:middle;">
			<input type="checkbox" id="home_autorefresh" data-role="none" checked> {{ trans('home.autorefresh') }}
		</label>
		<a href="{{ adminRouteUrl('containerlogs') }}" data-role="button" data-inline="true" data-mini="true" data-icon="action" style="margin-left:12px;">{{ trans('home.open_logs_fullpage') }}</a>
		<a href="{{ adminRouteUrl('diagnostics') }}" data-role="button" data-inline="true" data-mini="true" data-icon="search" style="margin-left:12px;">{{ trans('home.open_diagnostics') }}</a>
	</div>

	<p style="margin:0 0 4px;"><b>{{ trans('home.serverlog_title') }}</b></p>
	<pre id="homeserverlogbox" style="height:35vh; overflow:auto; background:#1e1e1e; color:#d4d4d4; padding:10px; border:1px solid #ddd; font-size:12px; line-height:1.35; white-space:pre; border-radius:4px; margin:0 0 12px;">{{ serverlog }}</pre>

	<p style="margin:0 0 4px;"><b>{{ trans('home.docker_title') }}</b></p>
	<pre id="homelogbox" style="height:25vh; overflow:auto; background:#1e1e1e; color:#d4d4d4; padding:10px; border:1px solid #ddd; font-size:12px; line-height:1.35; white-space:pre; border-radius:4px; margin:0;">{{ logs }}</pre>

	<script>
	(function () {
		var cb = document.getElementById('home_autorefresh');
		if (!cb) { return; }

		var boxes = { homeserverlogbox: 'serverlogbox', homelogbox: 'logbox' };
		Object.keys(boxes).forEach(function (id) {
			var box = document.getElementById(id);
			if (box) { box.scrollTop = box.scrollHeight; }
		});

		var url = "{{ adminRouteUrl('containerlogs') }}";
		var timer = null;

		function refresh() {
			fetch(url, { cache: 'no-store', credentials: 'same-origin' })
				.then(function (r) { return r.text(); })
				.then(function (html) {
					var doc = new DOMParser().parseFromString(html, 'text/html');
					Object.keys(boxes).forEach(function (id) {
						var box = document.getElementById(id);
						var src = doc.getElementById(boxes[id]);
						if (!box || !src) { return; }
						var atBottom = (box.scrollTop + box.clientHeight >= box.scrollHeight - 20);
						box.textContent = src.textContent;
						if (atBottom) { box.scrollTop = box.scrollHeight; }
					});
				})
				.catch(function () {});
		}
		function schedule() {
			if (cb.checked) { timer = setTimeout(function () { refresh(); schedule(); }, 5000); }
		}
		cb.addEventListener('change', function () {
			if (timer) { clearTimeout(timer); timer = null; }
			schedule();
		});
		schedule();
	})();

	// Poll the status fields (service status, container/controller version)
	// so "starting" turns into the real version without a full page reload.
	(function () {
		var url = "{{ adminRouteUrl('statusfragment') }}";
		var fields = ['fld_status', 'fld_container_version', 'fld_controller_version'];
		var hint = document.getElementById('failed_diag_hint');
		function poll() {
			fetch(url, { cache: 'no-store', credentials: 'same-origin' })
				.then(function (r) { return r.text(); })
				.then(function (html) {
					var doc = new DOMParser().parseFromString(html, 'text/html');
					fields.forEach(function (id) {
						var src = doc.getElementById(id);
						var dst = document.getElementById(id);
						if (src && dst) { dst.textContent = src.textContent.trim(); }
					});
					if (hint) {
						var statusEl = doc.getElementById('fld_status');
						var isFailed = statusEl && statusEl.textContent.trim() === 'failed';
						hint.style.display = isFailed ? '' : 'none';
					}
				})
				.catch(function () {});
		}
		setInterval(poll, 10000);
	})();
	</script>

	<div class="wide">{{ trans('home.configuration') }}</div>
	<p>
		<i>{{ trans('home.configuration_info') }}</i>
	</p>
	<p>{{ trans('home.configuration_howto') }}</p>
	<img src="{{ assetUrl('img/config_howto.png') }}" alt="Configuration howto">

	<div class="wide">Webinterface</div>
	<p>
		<i>{{ trans('home.home_explanation') }}</i>
	</p>
	<a href="{{unifi_url}}" target="_blank" class="ui-btn" id="openui" data-inline="true">{{ trans('home.open_ui')}}</a>
{% endblock %}
